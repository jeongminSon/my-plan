# Supabase 설정 (실제 값은 .env 에 넣고, .env 는 절대 커밋하지 않는다)
# Supabase 대시보드 → Project Settings → API 에서 확인:
#  - Project URL  → EXPO_PUBLIC_SUPABASE_URL
#  - anon public  → EXPO_PUBLIC_SUPABASE_ANON_KEY  (공개키, RLS로 보호되므로 프런트 노출 OK)
#
# ⚠️ service_role 키는 절대 프런트/이 파일에 두지 말 것 (서버 전용, RLS 우회 가능)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# (이미 사용 중인 동기화 서버 주소 — 참고용)
# EXPO_PUBLIC_SYNC_URL=https://my-plan-by-son.netlify.app/.netlify/functions/sync
